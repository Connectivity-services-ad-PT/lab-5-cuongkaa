{
  "name": "fit4110-access-gate",
  "version": "1.0.0",
  "description": "FIT4110 Access Gate integration with Business Core and Analytics",
  "private": true,
  "scripts": {
    "mock:gate": "prism mock contracts/access-gate.openapi.yaml --host 0.0.0.0 --port 4010",
    "lint:openapi": "spectral lint contracts/*.yaml",
    "test:compose": "newman run postman/collections/FIT4110_access_gate.postman_collection.json -e postman/environments/FIT4110_lab05_local.postman_environment.json -r cli,junit,htmlextra --reporter-junit-export reports/newman-lab05-compose.xml --reporter-htmlextra-export reports/newman-lab05-compose.html"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.10.0",
    "@stoplight/spectral-cli": "^6.13.1",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "wait-on": "^8.0.1"
  }
}
