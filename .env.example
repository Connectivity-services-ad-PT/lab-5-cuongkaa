# Access Gate API
APP_HOST=0.0.0.0
APP_PORT=8000
AUTH_TOKEN=local-dev-token
SERVICE_NAME=access-gate
SERVICE_VERSION=1.0.0
ENV=local
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=gate
POSTGRES_PASSWORD=gatepass
POSTGRES_DB=gatedb
DATABASE_URL=postgresql://gate:gatepass@db:5432/gatedb

# Local mocks. At Buoi 6, replace hostnames with partner laptop IP addresses.
CORE_SERVICE_URL=http://mock-core:8001
CORE_ACCESS_PATH=/api/v1/access-events
CORE_AUTH_TOKEN=local-dev-token
ANALYTICS_SERVICE_URL=http://mock-analytics:8002
ANALYTICS_EVENT_PATH=/api/v1/events/access
ANALYTICS_AUTH_TOKEN=local-dev-token
DEPENDENCY_TIMEOUT_SECONDS=5
DEPENDENCY_RETRIES=1

# MQTT RFID integration.
# Keep disabled for local CI/Newman checks. Enable in .env only when demoing with
# HiveMQ or a partner Mosquitto broker.
MQTT_ENABLED=false
MQTT_HOST=
MQTT_PORT=8883
MQTT_TLS=true
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_INPUT_TOPIC=smart-campus/raw/access/rfid-uid
MQTT_OUTPUT_TOPIC=smart-campus/events/access
WHITELIST_PATH=Acessgate_uid_whitelist.csv
